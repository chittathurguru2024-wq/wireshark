from scapy.all import *

packets = rdpcap(r"C:\Users\student\Desktop\capture.pcapng")

total_packets = len(packets)
total_size = sum(len(pkt) for pkt in packets)

header_size = 0
data_size = 0

for pkt in packets:
    pkt_len = len(pkt)
    
    if pkt.haslayer(IP):
        ip_header = pkt[IP].ihl * 4
        header_size += ip_header
        
        if pkt.haslayer(TCP):
            tcp_header = pkt[TCP].dataofs * 4
            header_size += tcp_header
            data_size += pkt_len - (ip_header + tcp_header)
        
        elif pkt.haslayer(UDP):
            header_size += 8
            data_size += pkt_len - (ip_header + 8)

print("Total number of packets:", total_packets)
print("Size of data:", data_size, "bytes")
print("Size of headers:", header_size, "bytes")


